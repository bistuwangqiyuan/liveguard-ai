{
  "name": "liveguard-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "守播 LiveGuard AI · workspaces root",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.4.0",
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=9.0"
  },
  "scripts": {
    "build": "pnpm -r --parallel build",
    "dev:console": "pnpm --filter @liveguard/console dev",
    "dev:extension": "pnpm --filter @liveguard/extension dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "3.3.2",
    "typescript": "5.5.3"
  }
}
